@model AppWebBeachSA.Models.Paquete

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Create</h1>

<h4>Paquete</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mt-2">
                <label asp-for="IdPaquete" class="control-label"></label>
                <input asp-for="IdPaquete" class="form-control" />
                <span asp-validation-for="IdPaquete" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                <label asp-for="NombrePaquete" class="control-label"></label>
                <input asp-for="NombrePaquete" class="form-control" />
                <span asp-validation-for="NombrePaquete" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                <label asp-for="Destino" class="control-label"></label>
                <input asp-for="Destino" class="form-control" />
                <span asp-validation-for="Destino" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                <label asp-for="FechaInicio" class="control-label"></label>
                <input asp-for="FechaInicio" class="form-control" />
                <span asp-validation-for="FechaInicio" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                <label asp-for="FechaFin" class="control-label"></label>
                <input asp-for="FechaFin" class="form-control" />
                <span asp-validation-for="FechaFin" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                <label asp-for="PrecioPorNoche" class="control-label"></label>
                <input asp-for="PrecioPorNoche" class="form-control" />
                <span asp-validation-for="PrecioPorNoche" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                <label asp-for="PorcentajePrima" class="control-label"></label>
                <input asp-for="PorcentajePrima" class="form-control" />
                <span asp-validation-for="PorcentajePrima" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                <label asp-for="Mensualidades" class="control-label"></label>
                <input asp-for="Mensualidades" class="form-control" />
                <span asp-validation-for="Mensualidades" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                <input type="submit" value="Crear" class="btn btn-primary mt-2" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index" class="btn btn-secondary mt-2">Regresar a la lista...</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}