@model AppWebBeachSA.Models.Usuario
@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <h2 class="text-center mb-4">Iniciar Sesión</h2>

            @if (TempData["MensajeLogin"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["MensajeLogin"]
                </div>
            }

            <form asp-action="Login" method="post">
                <div class="form-group mb-3">
                    <label asp-for="Username" class="form-label">Nombre de Usuario</label>
                    <input asp-for="Username" class="form-control" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Contrasenna" class="form-label">Contraseña</label>
                    <input asp-for="Contrasenna" class="form-control" type="password" />
                    <span asp-validation-for="Contrasenna" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">Ingresar</button>
            </form>

            <div class="text-center mt-3">
                <p>¿No tienes cuenta? <a asp-action="Create" asp-controller="Usuarios">Registrar</a></p>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
